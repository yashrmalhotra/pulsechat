{
  "compilerOptions": {
    /* Project structure */
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmitOnError": false,

    /* Node environment */
    "target": "ES2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    

    /* Types */
    "types": ["node"],
    "lib": ["ES2020"],

    /* Output */
    "sourceMap": true,
    "declaration": false,

    /* Type safety */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Interop */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Build safety */
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
